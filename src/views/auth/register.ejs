<div class="auth-card">
    <div class="auth-header">
        <img src="/img/logo.png" alt="Stats Visoro" style="width:80px;height:80px;border-radius:12px;" class="mb-2">
        <h1>Stats Visoro</h1>
        <p class="text-muted">Creare cont nou</p>
    </div>

    <%- include('../partials/flash') %>

        <form action="/register" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Nume</label>
                <input type="text" class="form-control" id="name" name="name" required>
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <input type="email" class="form-control" id="email" name="email" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Parolă</label>
                <input type="password" class="form-control" id="password" name="password" required minlength="6">
            </div>
            <div class="mb-3">
                <label for="password2" class="form-label">Confirmare parolă</label>
                <input type="password" class="form-control" id="password2" name="password2" required minlength="6">
            </div>
            <button type="submit" class="btn btn-primary w-100 mb-3">Înregistrare</button>
        </form>
        <p class="text-center text-muted mb-0">
            Ai deja cont? <a href="/login">Autentificare</a>
        </p>
</div>