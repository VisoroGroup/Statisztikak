<div class="mt-4 mb-4">
    <h2><i class="bi bi-journal-text me-2"></i>Jurnal Audit</h2>
    <p class="text-muted">Total: <%= total %> înregistrări</p>
    <%- include('../partials/flash') %>
        <div class="card">
            <div class="card-body p-0">
                <% if (logs.length===0) { %>
                    <div class="text-center text-muted py-5"><i class="bi bi-journal d-block"
                            style="font-size:3rem;opacity:0.3;"></i>
                        <p class="mt-2">Nu există evenimente înregistrate.</p>
                    </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Data/Ora</th>
                                        <th>Utilizator</th>
                                        <th>Acțiune</th>
                                        <th>Tip</th>
                                        <th>Detalii</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% logs.forEach(log=> { %>
                                        <tr>
                                            <td class="text-nowrap">
                                                <%= new Date(log.createdAt).toLocaleString('ro-RO') %>
                                            </td>
                                            <td>
                                                <%= log.user ? log.user.name : 'Sistem' %>
                                            </td>
                                            <td><span
                                                    class="badge <%= log.action === 'create' ? 'bg-success' : log.action === 'update' ? 'bg-warning text-dark' : log.action === 'delete' ? 'bg-danger' : log.action === 'login' ? 'bg-info' : 'bg-secondary' %>">
                                                    <%= log.action %>
                                                </span></td>
                                            <td><code><%= log.entityType %></code>
                                                <% if (log.entityId) { %><span class="text-muted">#<%= log.entityId %>
                                                            </span>
                                                    <% } %>
                                            </td>
                                            <td>
                                                <% if (log.details) { %><button class="btn btn-sm btn-outline-secondary"
                                                        onclick="alert(JSON.stringify(<%= JSON.stringify(log.details) %>, null, 2))"><i
                                                            class="bi bi-eye"></i></button>
                                                    <% } %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
            </div>
        </div>
        <% if (totalPages> 1) { %>
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item <%= page <= 1 ? 'disabled' : '' %>"><a class="page-link"
                            href="?page=<%= page - 1 %>">Anterior</a></li>
                    <% for (let i=1; i <=totalPages; i++) { %>
                        <li class="page-item <%= page === i ? 'active' : '' %>"><a class="page-link"
                                href="?page=<%= i %>">
                                <%= i %>
                            </a></li>
                        <% } %>
                            <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>"><a class="page-link"
                                    href="?page=<%= page + 1 %>">Următor</a></li>
                </ul>
            </nav>
            <% } %>
</div>