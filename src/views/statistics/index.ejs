<!-- Toolbar -->
<div class="toolbar mt-4 mb-4">
    <div class="row align-items-center g-3">
        <div class="col-auto">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="showValuesToggle" checked>
                <label class="form-check-label" for="showValuesToggle">Értékek Megjelenítés</label>
            </div>
        </div>
        <div class="col-auto">
            <select class="form-select form-select-sm" id="groupFilter" onchange="filterByGroup(this.value)">
                <option value="all" <%=currentGroup==='all' ? 'selected' : '' %>>Mindet</option>
                <% groups.forEach(g=> { %>
                    <option value="<%= g.name %>" <%=currentGroup===g.name ? 'selected' : '' %>><%= g.name %>
                    </option>
                    <% }); %>
            </select>
        </div>
        <div class="col-auto">
            <div class="dropdown">
                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-three-dots-vertical"></i> Teendő
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="/<%= orgId %>/statistics/create-graph">
                            <i class="bi bi-plus-circle me-2"></i>Új statisztika
                        </a></li>
                </ul>
            </div>
        </div>
        <div class="col">
            <form class="d-flex" method="GET" action="/<%= orgId %>/statistics">
                <input type="hidden" name="group" value="<%= currentGroup %>">
                <input type="text" class="form-control form-control-sm me-2" name="search" value="<%= search %>"
                    placeholder="Keresés cím szerint...">
                <button type="submit" class="btn btn-sm btn-primary">
                    <i class="bi bi-search"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Statistics Grid -->
<% if (statistics.length===0) { %>
    <div class="empty-state">
        <i class="bi bi-graph-up"></i>
        <h3>Nincs statisztika</h3>
        <p class="text-muted">Hozzon létre az első statisztikát a "Teendő" menüből.</p>
        <a href="/<%= orgId %>/statistics/create-graph" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Új statisztika
        </a>
    </div>
    <% } else { %>
        <div class="row g-4" id="statisticsGrid">
            <% statistics.forEach(stat=> { %>
                <div class="col-lg-6 stat-card-wrapper"
                    data-groups="<%= stat.groupAssignments.map(a => a.group.name).join(',') %>">
                    <div class="card stat-card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <a href="/<%= orgId %>/statistics/detail-graph/<%= stat.id %>" class="stat-title">
                                    <%= stat.title %>
                                </a>
                                <% if (stat.responsiblePerson) { %>
                                    <div class="stat-assigned">
                                        <i class="bi bi-person-fill me-1"></i>
                                        <%= stat.responsiblePerson.name %>
                                    </div>
                                    <% } %>
                            </div>
                            <button class="btn btn-sm btn-outline-primary add-value-btn" data-stat-id="<%= stat.id %>"
                                data-stat-title="<%= stat.title %>" title="Érték bevitele">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                        <div class="card-body p-2">
                            <div class="chart-container" id="chart-<%= stat.id %>" data-stat-id="<%= stat.id %>">
                                <div class="chart-loading">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
        </div>
        <% } %>

            <!-- Add Value Modal -->
            <div class="modal fade" id="addValueModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form id="addValueForm" method="POST">
                            <input type="hidden" name="form_type" value="add_value">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Érték bevitele</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <p class="text-muted" id="addValueStatTitle"></p>
                                <div class="mb-3">
                                    <label for="valueInput" class="form-label">Érték</label>
                                    <input type="number" step="0.01" class="form-control" id="valueInput" name="value"
                                        required>
                                </div>
                                <div class="mb-3">
                                    <label for="dateInput" class="form-label">Dátum</label>
                                    <input type="date" class="form-control" id="dateInput" name="for_date" required>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Ha nem munkanap:</label>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="when_weekend" value="before"
                                            id="weekendBefore">
                                        <label class="form-check-label" for="weekendBefore">Előtt 07:00AM (előző
                                            munkanapra)</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="when_weekend" value="after"
                                            id="weekendAfter" checked>
                                        <label class="form-check-label" for="weekendAfter">Után 07:00AM (következő
                                            munkanapra)</label>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bezár</button>
                                <button type="submit" class="btn btn-primary"><i
                                        class="bi bi-check-lg me-1"></i>Bevitel</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <script>
                const orgId = '<%= orgId %>';
                const statisticIds = [<%= statistics.map(s => s.id).join(',') %>];

                // Set today's date as default
                document.getElementById('dateInput').valueAsDate = new Date();

                // Open add value modal from card
                document.querySelectorAll('.add-value-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.preventDefault();
                        const statId = btn.dataset.statId;
                        const statTitle = btn.dataset.statTitle;
                        document.getElementById('addValueStatTitle').textContent = statTitle;
                        document.getElementById('addValueForm').action = '/' + orgId + '/statistics/detail-graph/' + statId;
                        new bootstrap.Modal(document.getElementById('addValueModal')).show();
                    });
                });

                // Filter by group (client-side for speed)
                function filterByGroup(group) {
                    const url = new URL(window.location);
                    url.searchParams.set('group', group);
                    window.location = url;
                }
            </script>