<div class="mt-4 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-speedometer2 me-2"></i>Stări de funcționare</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newConditionModal">
            <i class="bi bi-plus-lg me-1"></i>Stare nouă
        </button>
    </div>

    <%- include('../partials/flash') %>

        <!-- Filters -->
        <div class="card mb-3">
            <div class="card-body">
                <form method="GET" class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label">Angajat</label>
                        <select class="form-select" name="user" onchange="this.form.submit()">
                            <option value="">Eu</option>
                            <% users.forEach(u=> { %>
                                <option value="<%= u.id %>" <%=filterUser==u.id ? 'selected' : '' %>><%= u.name %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Grafic</label>
                        <select class="form-select" name="stat" onchange="this.form.submit()">
                            <option value="">Toate graficele</option>
                            <% statistics.forEach(s=> { %>
                                <option value="<%= s.id %>" <%=filterStat==s.id ? 'selected' : '' %>><%= s.title %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </form>
            </div>
        </div>

        <!-- Hubbard hierarchy reference -->
        <div class="card mb-3">
            <div class="card-body p-2">
                <div class="d-flex flex-wrap gap-2 justify-content-center">
                    <% CONDITION_ORDER.forEach(key=> { %>
                        <span class="badge" style="background:<%= CONDITION_COLORS[key] %>; font-size: 0.75rem;">
                            <%= CONDITION_LABELS[key] %>
                        </span>
                        <% }); %>
                </div>
            </div>
        </div>

        <!-- Conditions table -->
        <div class="card">
            <div class="card-body p-0">
                <% if (conditions.length===0) { %>
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-speedometer d-block" style="font-size:3rem;opacity:0.3;"></i>
                        <p class="mt-2">Nu există stări înregistrate.</p>
                    </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Data</th>
                                        <th>Angajat</th>
                                        <th>Stare</th>
                                        <th>Grafic</th>
                                        <th class="text-end">Acțiuni</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% conditions.forEach(c=> { %>
                                        <tr>
                                            <td>
                                                <%= new Date(c.conditionDate).toLocaleDateString('ro-RO') %>
                                            </td>
                                            <td>
                                                <%= c.user.name %>
                                            </td>
                                            <td><span class="badge"
                                                    style="background:<%= CONDITION_COLORS[c.conditionType] %>">
                                                    <%= CONDITION_LABELS[c.conditionType] %>
                                                </span></td>
                                            <td>
                                                <%= c.statistic ? c.statistic.title : '—' %>
                                            </td>
                                            <td class="text-end">
                                                <a href="/<%= orgId %>/statistics/graph-condition/<%= c.id %>"
                                                    class="btn btn-sm btn-outline-primary me-1" title="Write-Up">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <button class="btn btn-sm btn-outline-secondary edit-cond-btn me-1"
                                                    data-id="<%= c.id %>" data-type="<%= c.conditionType %>"
                                                    data-date="<%= new Date(c.conditionDate).toISOString().split('T')[0] %>"
                                                    data-stat="<%= c.statisticId || '' %>">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form action="/<%= orgId %>/statistics/conditions/<%= c.id %>/delete"
                                                    method="POST" class="d-inline"
                                                    onsubmit="return confirm('Sigur doriți să ștergeți?')">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                                            class="bi bi-trash"></i></button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% }); %>
                                </tbody>
                            </table>
                        </div>
                        <% } %>
            </div>
        </div>
</div>

<!-- New Condition Modal -->
<div class="modal fade" id="newConditionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="/<%= orgId %>/statistics/conditions" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Selectare stare</h5><button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Data</label><input type="date" class="form-control"
                            name="condition_date" required value="<%= new Date().toISOString().split('T')[0] %>"></div>
                    <div class="mb-3"><label class="form-label">Stare de funcționare</label>
                        <select class="form-select" name="condition_type" required>
                            <% CONDITION_ORDER.forEach(key=> { %>
                                <option value="<%= key %>">
                                    <%= CONDITION_LABELS[key] %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label">Grafic</label>
                        <select class="form-select" name="statistic_id">
                            <option value="">Toate graficele</option>
                            <% statistics.forEach(s=> { %>
                                <option value="<%= s.id %>">
                                    <%= s.title %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">Închide</button><button type="submit"
                        class="btn btn-primary">Salvare</button></div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Condition Modal -->
<div class="modal fade" id="editConditionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form id="editCondForm" method="POST">
                <div class="modal-header">
                    <h5 class="modal-title">Editare stare</h5><button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3"><label class="form-label">Data</label><input type="date" class="form-control"
                            name="condition_date" id="editCondDate" required></div>
                    <div class="mb-3"><label class="form-label">Stare de funcționare</label>
                        <select class="form-select" name="condition_type" id="editCondType">
                            <% CONDITION_ORDER.forEach(key=> { %>
                                <option value="<%= key %>">
                                    <%= CONDITION_LABELS[key] %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                    <div class="mb-3"><label class="form-label">Grafic</label>
                        <select class="form-select" name="statistic_id" id="editCondStat">
                            <option value="">Toate graficele</option>
                            <% statistics.forEach(s=> { %>
                                <option value="<%= s.id %>">
                                    <%= s.title %>
                                </option>
                                <% }); %>
                        </select>
                    </div>
                </div>
                <div class="modal-footer"><button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">Închide</button><button type="submit"
                        class="btn btn-primary">Salvare</button></div>
            </form>
        </div>
    </div>
</div>

<script>
    const orgId = '<%= orgId %>';

    // Edit condition buttons
    document.querySelectorAll('.edit-cond-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.getElementById('editCondForm').action = '/' + orgId + '/statistics/conditions/' + btn.dataset.id + '/edit';
            document.getElementById('editCondDate').value = btn.dataset.date;
            document.getElementById('editCondType').value = btn.dataset.type;
            document.getElementById('editCondStat').value = btn.dataset.stat;
            new bootstrap.Modal(document.getElementById('editConditionModal')).show();
        });
    });

    // Auto-suggest condition when statistic is selected
    const newStatSelect = document.querySelector('#newConditionModal select[name="statistic_id"]');
    const newCondTypeSelect = document.querySelector('#newConditionModal select[name="condition_type"]');
    const suggestBadge = document.createElement('span');
    suggestBadge.className = 'badge bg-info ms-2';
    suggestBadge.style.display = 'none';
    suggestBadge.id = 'autoSuggestBadge';
    newCondTypeSelect.parentNode.appendChild(suggestBadge);

    if (newStatSelect) {
        newStatSelect.addEventListener('change', async () => {
            const statId = newStatSelect.value;
            suggestBadge.style.display = 'none';
            if (!statId) return;

            try {
                const res = await fetch('/' + orgId + '/statistics/conditions/suggest/' + statId);
                const data = await res.json();
                if (data.success && data.suggested) {
                    // Pre-select the suggested condition
                    newCondTypeSelect.value = data.suggested;
                    suggestBadge.textContent = '(sugestie automată: ' + data.message + ')';
                    suggestBadge.style.display = 'inline';
                }
            } catch (err) {
                console.error('Auto-suggest error:', err);
            }
        });
    }
</script>